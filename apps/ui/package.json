{
  "name": "@codex-symphony-demo/ui",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "copy:openapi": "cp ../backend/openapi.json openapi.json",
    "generate:client": "npm run copy:openapi && openapi-sdkgen ./openapi.json ./generated",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "test": "tsc -b --pretty false"
  },
  "dependencies": {
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.0",
    "vite": "^7.2.7"
  }
}
