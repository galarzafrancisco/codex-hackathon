{
  "openapi": "3.0.0",
  "paths": {
    "/api/v1/health": {
      "get": {
        "operationId": "HealthController_getHealth",
        "parameters": [],
        "responses": {
          "200": {
            "description": "The backend is running.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponseDto"
                }
              }
            }
          }
        },
        "summary": "Read backend health",
        "tags": [
          "health"
        ]
      }
    },
    "/api/v1/codex/models": {
      "get": {
        "operationId": "CodexController_listModels",
        "parameters": [
          {
            "name": "include_hidden",
            "required": false,
            "in": "query",
            "description": "Include models Codex marks as hidden from the default picker.",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "cursor",
            "required": false,
            "in": "query",
            "description": "Opaque pagination cursor returned by Codex app-server.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "required": false,
            "in": "query",
            "description": "Maximum number of models to return.",
            "schema": {
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Models available to Codex app-server.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListCodexModelsResponseDto"
                }
              }
            }
          }
        },
        "summary": "List Codex app-server models",
        "tags": [
          "codex"
        ]
      }
    },
    "/api/v1/codex/threads": {
      "get": {
        "operationId": "CodexController_listThreads",
        "parameters": [
          {
            "name": "search_term",
            "required": false,
            "in": "query",
            "description": "Search stored thread summaries and metadata.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "cwd",
            "required": false,
            "in": "query",
            "description": "Restrict results to threads whose current working directory exactly matches this path.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "archived",
            "required": false,
            "in": "query",
            "description": "List archived threads instead of active threads.",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "sort_key",
            "required": false,
            "in": "query",
            "description": "Thread sort key.",
            "schema": {
              "enum": [
                "created_at",
                "updated_at"
              ],
              "type": "string"
            }
          },
          {
            "name": "cursor",
            "required": false,
            "in": "query",
            "description": "Opaque pagination cursor returned by Codex app-server.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "required": false,
            "in": "query",
            "description": "Maximum number of threads to return.",
            "schema": {
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Threads returned by Codex app-server.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListCodexThreadsResponseDto"
                }
              }
            }
          }
        },
        "summary": "List Codex app-server threads",
        "tags": [
          "codex"
        ]
      },
      "post": {
        "operationId": "CodexController_startThread",
        "parameters": [],
        "requestBody": {
          "required": true,
          "description": "Options for the new Codex thread.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StartCodexThreadRequestDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "The Codex thread was started.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StartCodexThreadResponseDto"
                }
              }
            }
          }
        },
        "summary": "Start a new Codex app-server thread",
        "tags": [
          "codex"
        ]
      }
    },
    "/api/v1/issues": {
      "get": {
        "operationId": "IssuesController_listIssues",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Issues sorted for dispatch.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListIssuesResponseDto"
                }
              }
            }
          }
        },
        "summary": "List normalized issues",
        "tags": [
          "issues"
        ]
      },
      "post": {
        "operationId": "IssuesController_createIssue",
        "parameters": [],
        "requestBody": {
          "required": true,
          "description": "Issue fields to create.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateIssueRequestDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "The issue was created.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IssueResponseDto"
                }
              }
            }
          }
        },
        "summary": "Create a tracker issue",
        "tags": [
          "issues"
        ]
      }
    },
    "/api/v1/issues/{id}": {
      "get": {
        "operationId": "IssuesController_getIssue",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "description": "Stable tracker-internal issue ID.",
            "schema": {
              "example": "issue_01HZY8Z3P8M5N7R1E2A4C6D9F0",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The normalized issue record.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IssueResponseDto"
                }
              }
            }
          },
          "404": {
            "description": "No issue exists for the requested tracker-internal ID."
          }
        },
        "summary": "Read a normalized issue",
        "tags": [
          "issues"
        ]
      },
      "put": {
        "operationId": "IssuesController_upsertIssue",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "description": "Stable tracker-internal issue ID.",
            "schema": {
              "example": "issue_01HZY8Z3P8M5N7R1E2A4C6D9F0",
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "description": "Normalized issue record fields to create or replace.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpsertIssueRequestDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The normalized issue record was stored.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IssueResponseDto"
                }
              }
            }
          }
        },
        "summary": "Create or replace a normalized issue",
        "tags": [
          "issues"
        ]
      }
    }
  },
  "info": {
    "title": "Codex Symphony Backend",
    "description": "Starter backend API for the Codex Symphony monorepo.",
    "version": "0.0.1",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "schemas": {
      "HealthResponseDto": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "Current backend health status.",
            "enum": [
              "ok"
            ],
            "example": "ok"
          },
          "service": {
            "type": "string",
            "description": "Stable service identifier for the backend API.",
            "example": "backend"
          },
          "timestamp": {
            "type": "string",
            "description": "UTC timestamp for when the health response was produced.",
            "example": "2026-04-29T00:00:00.000Z",
            "format": "date-time"
          }
        },
        "required": [
          "status",
          "service",
          "timestamp"
        ]
      },
      "CodexReasoningEffortResponseDto": {
        "type": "object",
        "properties": {
          "reasoning_effort": {
            "type": "string",
            "description": "Reasoning effort value accepted by the Codex model.",
            "example": "medium"
          },
          "description": {
            "type": "string",
            "description": "Human-readable description of the effort option.",
            "example": "Balances latency and reasoning depth.",
            "nullable": true
          }
        },
        "required": [
          "reasoning_effort"
        ]
      },
      "CodexModelResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Stable model identifier returned by Codex app-server.",
            "example": "gpt-5.4"
          },
          "model": {
            "type": "string",
            "description": "Model value to send when starting Codex threads.",
            "example": "gpt-5.4"
          },
          "display_name": {
            "type": "string",
            "description": "Display label suitable for model selectors.",
            "example": "GPT-5.4",
            "nullable": true
          },
          "hidden": {
            "type": "boolean",
            "description": "Whether Codex marks this model as hidden from default pickers.",
            "example": false
          },
          "default_reasoning_effort": {
            "type": "string",
            "description": "Default reasoning effort recommended by Codex for this model.",
            "example": "medium",
            "nullable": true
          },
          "supported_reasoning_efforts": {
            "description": "Reasoning effort options supported by the model.",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CodexReasoningEffortResponseDto"
            }
          },
          "input_modalities": {
            "description": "Input modalities accepted by the model.",
            "example": [
              "text",
              "image"
            ],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "supports_personality": {
            "type": "boolean",
            "description": "Whether the model supports personality-specific instructions.",
            "example": true,
            "nullable": true
          },
          "is_default": {
            "type": "boolean",
            "description": "Whether Codex marks this as the recommended default model.",
            "example": true
          }
        },
        "required": [
          "id",
          "model",
          "hidden",
          "supported_reasoning_efforts",
          "input_modalities",
          "is_default"
        ]
      },
      "ListCodexModelsResponseDto": {
        "type": "object",
        "properties": {
          "models": {
            "description": "Models returned by Codex app-server.",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CodexModelResponseDto"
            }
          },
          "next_cursor": {
            "type": "string",
            "description": "Opaque cursor for the next page, or null when all models have been returned.",
            "example": null,
            "nullable": true
          }
        },
        "required": [
          "models"
        ]
      },
      "CodexThreadStatusResponseDto": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "description": "Runtime thread status type reported by Codex app-server.",
            "example": "notLoaded"
          },
          "active_flags": {
            "description": "Active status flags when the thread is currently loaded and running.",
            "example": [
              "waitingOnApproval"
            ],
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "type",
          "active_flags"
        ]
      },
      "CodexThreadResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Stable Codex thread identifier.",
            "example": "thr_123"
          },
          "name": {
            "type": "string",
            "description": "User-facing thread name when Codex has assigned one.",
            "example": "Bug bash notes",
            "nullable": true
          },
          "preview": {
            "type": "string",
            "description": "Preview text for the thread history UI.",
            "example": "Fix tests",
            "nullable": true
          },
          "ephemeral": {
            "type": "boolean",
            "description": "Whether the Codex thread is ephemeral.",
            "example": false
          },
          "model_provider": {
            "type": "string",
            "description": "Model provider recorded for the thread.",
            "example": "openai",
            "nullable": true
          },
          "created_at": {
            "type": "string",
            "description": "Thread creation time as an ISO timestamp when Codex provides it.",
            "example": "2026-04-29T04:20:00.000Z",
            "nullable": true
          },
          "updated_at": {
            "type": "string",
            "description": "Last thread update time as an ISO timestamp when Codex provides it.",
            "example": "2026-04-29T04:30:00.000Z",
            "nullable": true
          },
          "status": {
            "description": "Runtime status reported by Codex app-server.",
            "nullable": true,
            "type": "object",
            "allOf": [
              {
                "$ref": "#/components/schemas/CodexThreadStatusResponseDto"
              }
            ]
          }
        },
        "required": [
          "id",
          "ephemeral"
        ]
      },
      "ListCodexThreadsResponseDto": {
        "type": "object",
        "properties": {
          "threads": {
            "description": "Threads returned by Codex app-server.",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CodexThreadResponseDto"
            }
          },
          "next_cursor": {
            "type": "string",
            "description": "Opaque cursor for the next page, or null when all threads have been returned.",
            "example": null,
            "nullable": true
          }
        },
        "required": [
          "threads"
        ]
      },
      "StartCodexThreadRequestDto": {
        "type": "object",
        "properties": {
          "model": {
            "type": "string",
            "description": "Model to use for the new Codex thread. Omit to let Codex choose its default.",
            "example": "gpt-5.4"
          },
          "cwd": {
            "type": "string",
            "description": "Working directory for the new Codex thread.",
            "example": "/Users/me/project"
          },
          "approval_policy": {
            "type": "string",
            "description": "Approval policy override for the new thread.",
            "enum": [
              "untrusted",
              "on-request",
              "never"
            ],
            "example": "on-request"
          },
          "sandbox": {
            "type": "string",
            "description": "Sandbox policy override for the new thread.",
            "enum": [
              "readOnly",
              "workspaceWrite",
              "dangerFullAccess"
            ],
            "example": "workspaceWrite"
          },
          "personality": {
            "type": "string",
            "description": "Codex personality preset for the new thread.",
            "example": "friendly"
          },
          "service_name": {
            "type": "string",
            "description": "Service name attached to thread-level Codex metrics.",
            "example": "codex_symphony_demo"
          }
        }
      },
      "StartCodexThreadResponseDto": {
        "type": "object",
        "properties": {
          "thread": {
            "description": "Thread created by Codex app-server.",
            "allOf": [
              {
                "$ref": "#/components/schemas/CodexThreadResponseDto"
              }
            ]
          }
        },
        "required": [
          "thread"
        ]
      },
      "IssueBlockerRefResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Stable tracker-internal ID for the blocking issue when known.",
            "example": "issue_01HZY8Z3P8M5N7R1E2A4C6D9F1",
            "nullable": true
          },
          "identifier": {
            "type": "string",
            "description": "Human-readable ticket key for the blocking issue when known.",
            "example": "ABC-122",
            "nullable": true
          },
          "state": {
            "type": "string",
            "description": "Current tracker state name for the blocking issue when known.",
            "example": "In Progress",
            "nullable": true
          },
          "created_at": {
            "type": "string",
            "description": "Tracker creation timestamp for the blocking issue when known.",
            "example": "2026-04-29T00:00:00.000Z",
            "format": "date-time",
            "nullable": true
          },
          "updated_at": {
            "type": "string",
            "description": "Tracker update timestamp for the blocking issue when known.",
            "example": "2026-04-29T01:00:00.000Z",
            "format": "date-time",
            "nullable": true
          }
        },
        "required": [
          "id",
          "identifier",
          "state",
          "created_at",
          "updated_at"
        ]
      },
      "IssueResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Stable tracker-internal issue ID.",
            "example": "issue_01HZY8Z3P8M5N7R1E2A4C6D9F0"
          },
          "identifier": {
            "type": "string",
            "description": "Human-readable ticket key.",
            "example": "ABC-123"
          },
          "title": {
            "type": "string",
            "description": "Issue title.",
            "example": "Implement worker dispatch queue"
          },
          "description": {
            "type": "string",
            "description": "Issue description, if the tracker provided one.",
            "example": "Build the queue used by orchestration to dispatch agent runs.",
            "nullable": true
          },
          "priority": {
            "type": "number",
            "description": "Dispatch priority. Lower numbers are higher priority.",
            "example": 1,
            "nullable": true
          },
          "state": {
            "type": "string",
            "description": "Current tracker state name.",
            "example": "Ready"
          },
          "branch_name": {
            "type": "string",
            "description": "Tracker-provided branch metadata if available.",
            "example": "feature/abc-123-worker-dispatch",
            "nullable": true
          },
          "url": {
            "type": "string",
            "description": "Tracker issue URL if available.",
            "example": "https://tracker.example.com/ABC-123",
            "nullable": true
          },
          "labels": {
            "description": "Lowercase normalized issue labels.",
            "example": [
              "backend",
              "orchestration"
            ],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "blocked_by": {
            "description": "Normalized blocker references for the issue.",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/IssueBlockerRefResponseDto"
            }
          }
        },
        "required": [
          "id",
          "identifier",
          "title",
          "description",
          "priority",
          "state",
          "branch_name",
          "url",
          "labels",
          "blocked_by"
        ]
      },
      "ListIssuesResponseDto": {
        "type": "object",
        "properties": {
          "issues": {
            "description": "Issues sorted for dispatch, with lower priorities first and null priorities last.",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/IssueResponseDto"
            }
          }
        },
        "required": [
          "issues"
        ]
      },
      "IssueBlockerRefRequestDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Stable tracker-internal ID for the blocking issue when known.",
            "example": "issue_01HZY8Z3P8M5N7R1E2A4C6D9F1",
            "nullable": true
          },
          "identifier": {
            "type": "string",
            "description": "Human-readable ticket key for the blocking issue when known.",
            "example": "ABC-122",
            "nullable": true
          },
          "state": {
            "type": "string",
            "description": "Current tracker state name for the blocking issue when known.",
            "example": "In Progress",
            "nullable": true
          },
          "created_at": {
            "type": "string",
            "description": "Tracker creation timestamp for the blocking issue when known.",
            "example": "2026-04-29T00:00:00.000Z",
            "format": "date-time",
            "nullable": true
          },
          "updated_at": {
            "type": "string",
            "description": "Tracker update timestamp for the blocking issue when known.",
            "example": "2026-04-29T01:00:00.000Z",
            "format": "date-time",
            "nullable": true
          }
        }
      },
      "CreateIssueRequestDto": {
        "type": "object",
        "properties": {
          "identifier": {
            "type": "string",
            "description": "Human-readable ticket key.",
            "example": "ABC-123"
          },
          "title": {
            "type": "string",
            "description": "Issue title.",
            "example": "Implement worker dispatch queue"
          },
          "description": {
            "type": "string",
            "description": "Issue description, if the tracker provided one.",
            "example": "Build the queue used by orchestration to dispatch agent runs.",
            "nullable": true
          },
          "priority": {
            "type": "number",
            "description": "Dispatch priority. Lower numbers are higher priority.",
            "example": 1,
            "nullable": true
          },
          "state": {
            "type": "string",
            "description": "Current tracker state name.",
            "example": "Ready"
          },
          "branch_name": {
            "type": "string",
            "description": "Tracker-provided branch metadata if available.",
            "example": "feature/abc-123-worker-dispatch",
            "nullable": true
          },
          "url": {
            "type": "string",
            "description": "Tracker issue URL if available.",
            "example": "https://tracker.example.com/ABC-123",
            "nullable": true
          },
          "labels": {
            "description": "Issue labels. Values are normalized to lowercase before storage.",
            "example": [
              "Backend",
              "Orchestration"
            ],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "blocked_by": {
            "description": "Normalized blocker references for the issue.",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/IssueBlockerRefRequestDto"
            }
          }
        },
        "required": [
          "identifier",
          "title",
          "state"
        ]
      },
      "UpsertIssueRequestDto": {
        "type": "object",
        "properties": {
          "identifier": {
            "type": "string",
            "description": "Human-readable ticket key.",
            "example": "ABC-123"
          },
          "title": {
            "type": "string",
            "description": "Issue title.",
            "example": "Implement worker dispatch queue"
          },
          "description": {
            "type": "string",
            "description": "Issue description, if the tracker provided one.",
            "example": "Build the queue used by orchestration to dispatch agent runs.",
            "nullable": true
          },
          "priority": {
            "type": "number",
            "description": "Dispatch priority. Lower numbers are higher priority.",
            "example": 1,
            "nullable": true
          },
          "state": {
            "type": "string",
            "description": "Current tracker state name.",
            "example": "Ready"
          },
          "branch_name": {
            "type": "string",
            "description": "Tracker-provided branch metadata if available.",
            "example": "feature/abc-123-worker-dispatch",
            "nullable": true
          },
          "url": {
            "type": "string",
            "description": "Tracker issue URL if available.",
            "example": "https://tracker.example.com/ABC-123",
            "nullable": true
          },
          "labels": {
            "description": "Issue labels. Values are normalized to lowercase before storage.",
            "example": [
              "Backend",
              "Orchestration"
            ],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "blocked_by": {
            "description": "Normalized blocker references for the issue.",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/IssueBlockerRefRequestDto"
            }
          }
        },
        "required": [
          "identifier",
          "title",
          "state"
        ]
      }
    }
  }
}
